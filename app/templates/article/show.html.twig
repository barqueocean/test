{# templates/article/show.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}
    {{ article.title }}
{% endblock %}

{% block body %}

    <div class="container" style="margin-top:200px">

        <h1>
            {{ article.title }}
        </h1>

        <p>
            Категория:
            {{ article.category.name }}
        </p>

        <p>
            Автор:
            {{ article.author.email }}
        </p>

        <p>
            {{ article.publishedAt|date('d.m.Y') }}
        </p>

        <hr>

        <div>
            {{ article.content }}
        </div>

    </div>

{% endblock %}
